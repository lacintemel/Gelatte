// ═══════════════════════════════════════════
// Gelatte — Prisma Schema
// PostgreSQL database schema for the e-commerce store
// ═══════════════════════════════════════════

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ── Users & Auth ──────────────────────────

enum UserRole {
  customer
  admin
  superadmin
}

model User {
  id                 String    @id @default(cuid())
  email              String    @unique
  name               String
  passwordHash       String
  phone              String    @default("")
  role               UserRole  @default(customer)
  deliveryPreference String    @default("delivery")
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt

  sessions   Session[]
  addresses  Address[]
  carts      Cart[]
  orders     Order[]
  reviews    Review[]
  auditLogs  AuditLog[]

  @@index([email])
  @@index([role])
}

model Session {
  id        String   @id @default(cuid())
  userId    String
  token     String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([token])
  @@index([userId])
}

// ── Addresses ─────────────────────────────

enum AddressType {
  shipping
  billing
}

model Address {
  id         String      @id @default(cuid())
  userId     String
  type       AddressType @default(shipping)
  firstName  String
  lastName   String
  phone      String      @default("")
  address    String
  city       String
  zip        String
  country    String      @default("TR")
  isDefault  Boolean     @default(false)
  createdAt  DateTime    @default(now())
  updatedAt  DateTime    @updatedAt

  user             User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  shippingOrders   Order[] @relation("ShippingAddress")
  billingOrders    Order[] @relation("BillingAddress")

  @@index([userId])
}

// ── Products ──────────────────────────────

model ProductCategory {
  id          String   @id @default(cuid())
  slug        String   @unique
  label       String
  description String   @default("")
  image       String   @default("")
  sortOrder   Int      @default(0)
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  products Product[]

  @@index([slug])
  @@index([isActive])
}

model Product {
  id                    String   @id @default(cuid())
  categoryId            String
  name                  String
  description           String   @default("")
  price                 Decimal  @db.Decimal(10, 2)
  discount              Decimal  @default(0) @db.Decimal(10, 2)
  stock                 Int      @default(0)
  badge                 String?
  status                String   @default("active") // active, draft, archived
  showInMenu            Boolean  @default(true)
  availableForOnlineOrder Boolean @default(true)
  sortOrder             Int      @default(0)
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  category   ProductCategory @relation(fields: [categoryId], references: [id])
  images     ProductImage[]
  variants   ProductVariant[]
  cartItems  CartItem[]
  orderItems OrderItem[]
  reviews    Review[]

  @@index([categoryId])
  @@index([status])
  @@index([availableForOnlineOrder])
}

model ProductImage {
  id        String   @id @default(cuid())
  productId String
  url       String
  alt       String   @default("")
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([productId])
}

model ProductVariant {
  id        String  @id @default(cuid())
  productId String
  name      String  // e.g., "Small", "Large", "Pistachio"
  type      String  // e.g., "size", "flavor"
  price     Decimal @db.Decimal(10, 2)
  stock     Int     @default(0)
  isActive  Boolean @default(true)
  sortOrder Int     @default(0)

  product   Product    @relation(fields: [productId], references: [id], onDelete: Cascade)
  cartItems CartItem[]

  @@index([productId])
}

// ── Cart ──────────────────────────────────

model Cart {
  id        String   @id @default(cuid())
  userId    String?
  guestId   String?  // For guest checkout
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user  User?      @relation(fields: [userId], references: [id], onDelete: Cascade)
  items CartItem[]

  @@index([userId])
  @@index([guestId])
}

model CartItem {
  id        String @id @default(cuid())
  cartId    String
  productId String
  variantId String?
  quantity  Int    @default(1)

  cart    Cart            @relation(fields: [cartId], references: [id], onDelete: Cascade)
  product Product         @relation(fields: [productId], references: [id])
  variant ProductVariant? @relation(fields: [variantId], references: [id])

  @@unique([cartId, productId, variantId])
  @@index([cartId])
}

// ── Orders ────────────────────────────────

enum OrderStatus {
  pending_payment
  confirmed
  preparing
  ready
  completed
  cancelled
  refunded
}

enum PaymentStatus {
  pending
  processing
  completed
  failed
  cancelled
  refunded
}

model Order {
  id                String      @id @default(cuid())
  orderNumber       String      @unique // Human-readable: GL-XXXXXX
  userId            String?
  status            OrderStatus @default(pending_payment)
  shippingAddressId String?
  billingAddressId  String?

  // Amounts (all in TRY, stored as Decimal for precision)
  subtotal       Decimal @db.Decimal(10, 2)
  discountAmount Decimal @default(0) @db.Decimal(10, 2)
  shippingFee    Decimal @default(0) @db.Decimal(10, 2)
  taxAmount      Decimal @default(0) @db.Decimal(10, 2)
  total          Decimal @db.Decimal(10, 2)

  // Coupon
  couponCode String?

  // Customer info snapshot (for guest orders or historical reference)
  customerEmail     String  @default("")
  customerFirstName String  @default("")
  customerLastName  String  @default("")
  customerPhone     String  @default("")

  // Idempotency
  idempotencyKey String? @unique

  notes     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user            User?     @relation(fields: [userId], references: [id])
  shippingAddress Address?  @relation("ShippingAddress", fields: [shippingAddressId], references: [id])
  billingAddress  Address?  @relation("BillingAddress", fields: [billingAddressId], references: [id])
  items           OrderItem[]
  payment         Payment?

  @@index([userId])
  @@index([orderNumber])
  @@index([status])
  @@index([createdAt])
}

model OrderItem {
  id        String  @id @default(cuid())
  orderId   String
  productId String
  name      String  // Snapshot at time of purchase
  price     Decimal @db.Decimal(10, 2)
  discount  Decimal @default(0) @db.Decimal(10, 2)
  quantity  Int
  image     String  @default("")

  order   Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id])

  @@index([orderId])
}

// ── Payments ──────────────────────────────

model Payment {
  id                    String        @id @default(cuid())
  orderId               String        @unique
  provider              String        @default("paytr") // paytr, iyzico, etc.
  status                PaymentStatus @default(pending)
  amount                Decimal       @db.Decimal(10, 2)
  currency              String        @default("TL")

  // Provider-specific references
  providerTransactionId String?
  providerToken         String?   // iframe token, checkout form token, etc.
  merchantOid           String?   @unique // Our order ID sent to provider

  // Idempotency
  idempotencyKey        String?   @unique

  // Timestamps
  paidAt                DateTime?
  failedAt              DateTime?
  cancelledAt           DateTime?
  refundedAt            DateTime?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  order        Order                @relation(fields: [orderId], references: [id])
  transactions PaymentTransaction[]

  @@index([orderId])
  @@index([merchantOid])
  @@index([providerTransactionId])
  @@index([status])
}

model PaymentTransaction {
  id        String   @id @default(cuid())
  paymentId String
  type      String   // callback, refund, cancel, status_check
  status    String   // raw status from provider
  rawData   String   @db.Text // Full provider response (JSON stringified)
  createdAt DateTime @default(now())

  payment Payment @relation(fields: [paymentId], references: [id], onDelete: Cascade)

  @@index([paymentId])
}

// ── Coupons ───────────────────────────────

model Coupon {
  id          String   @id @default(cuid())
  code        String   @unique
  type        String   @default("percent") // percent, fixed
  discount    Decimal  @db.Decimal(10, 2)
  minOrder    Decimal  @default(0) @db.Decimal(10, 2)
  maxUses     Int      @default(999)
  currentUses Int      @default(0)
  validFrom   DateTime
  validTo     DateTime
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([code])
  @@index([isActive])
}

// ── Reviews ───────────────────────────────

model Review {
  id        String   @id @default(cuid())
  productId String
  userId    String
  rating    Int      // 1-5
  comment   String   @default("")
  createdAt DateTime @default(now())

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([productId])
  @@index([userId])
}

// ── Store Settings ────────────────────────

model StoreSetting {
  id    String @id @default(cuid())
  key   String @unique
  value String @db.Text

  @@index([key])
}

// ── Audit Log ─────────────────────────────

model AuditLog {
  id        String   @id @default(cuid())
  userId    String?
  action    String   // e.g., "order.created", "payment.callback", "product.updated"
  entity    String   // e.g., "Order", "Payment", "Product"
  entityId  String?
  details   String?  @db.Text // JSON stringified
  ip        String   @default("")
  createdAt DateTime @default(now())

  user User? @relation(fields: [userId], references: [id])

  @@index([action])
  @@index([entity, entityId])
  @@index([createdAt])
}
